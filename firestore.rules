rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════
    // FUNÇÕES AUXILIARES
    // ══════════════════════════════════════════════════════

    // Verifica se o usuário está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Verifica se o uid do request bate com o documento
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Verifica se o usuário é o dono/fundador do escritório.
    // IMPORTANTE: o banco real tem DOIS nomes de campo coexistindo —
    // 'fundador_uid' (gravado por criar_escritorio.js no fluxo normal)
    // e 'dono_uid' (visto em documentos editados por outro caminho,
    // provavelmente a Cloud Function adminAction ou um schema mais
    // antigo). O próprio código já trata essa duplicidade explicitamente
    // em criar_escritorio.js: "donoFallback = escData.dono_uid ||
    // escData.fundador_uid" — esta função replica o mesmo fallback nas
    // regras de segurança, para não depender de qual dos dois nomes um
    // escritório específico usa.
    function isDono(escritorioData) {
      return isAuth() &&
        (escritorioData.dono_uid == request.auth.uid
         || escritorioData.fundador_uid == request.auth.uid);
    }

    // Verifica se o usuário é sócio do escritório
    // (confirmado em functions/criar_escritorio.js: o array simples de
    // UIDs é 'socios_uids' — 'socios' é um array de OBJETOS
    // {uid, participacao_pct, cargo}, então 'in' contra ele nunca daria
    // match.)
    function isSocio(escritorioData) {
      return isAuth() &&
        request.auth.uid in escritorioData.socios_uids;
    }

    // Verifica se o campo não está sendo alterado
    function notChanging(field) {
      return !(field in request.resource.data) ||
        request.resource.data[field] == resource.data[field];
    }

    // ══════════════════════════════════════════════════════
    // CONFIG DO SERVIDOR (somente leitura para jogadores)
    // ══════════════════════════════════════════════════════
    match /config/{doc} {
      allow read: if isAuth();
      allow write: if false; // somente Cloud Functions escrevem aqui
    }

    // ══════════════════════════════════════════════════════
    // JOGADORES
    // ══════════════════════════════════════════════════════
    match /jogadores/{uid} {
      // Qualquer autenticado pode LER dados públicos de outro jogador
      // (para rankings, escritórios, convites)
      allow read: if isAuth();

      // Criação: apenas o próprio usuário cria seu documento
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.reputacao <= 30
        && request.resource.data.dinheiro <= 15000;

      // Update: apenas o próprio usuário, com restrições
      allow update: if isOwner(uid)
        // Campos que NUNCA podem ser alterados pelo cliente diretamente
        && notChanging('uid')
        && notChanging('criado_em')
        && notChanging('geracao')
        // Reputação só pode subir até o cap do cargo (verificado no cliente,
        // validação real está nas Cloud Functions)
        && request.resource.data.reputacao >= 0
        && request.resource.data.reputacao <= 100
        // Dinheiro não pode ser inflado do nada
        && request.resource.data.dinheiro >= 0;

      // Deleção não permitida pelo cliente
      allow delete: if false;

      // ── Subcoleção: mensagens/inbox ──
      match /inbox/{msgId} {
        allow read: if isOwner(uid);
        // Criação de mensagem: qualquer autenticado pode enviar para outro
        allow create: if isAuth()
          && request.resource.data.de == request.auth.uid
          && request.resource.data.lida == false;
        // Update: apenas o destinatário (marcar como lida)
        allow update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['lida', 'lida_em']);
        allow delete: if isOwner(uid);
      }

      // ── Subcoleção: relacionamentos ──
      match /relacionamentos/{relId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);

        // ── Sub-subcoleção: eventos (timeline do perfil estilo Facebook) ──
        match /eventos/{eventoId} {
          allow read:   if isOwner(uid);
          allow create: if isOwner(uid);
          allow update: if isOwner(uid);
          allow delete: if isOwner(uid);
        }
      }

      // ── Subcoleção: filhos ──
      match /filhos/{filhoId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }
    }

    // ══════════════════════════════════════════════════════
    // NPCs GLOBAIS — LOCK DE EXCLUSIVIDADE
    // Cada NPC é única no mundo, compartilhada entre todos os jogadores.
    // Qualquer jogador autenticado precisa LER todos os locks (para saber
    // quem está disponível em "Conhecer Pessoas"). A ESCRITA só é permitida
    // quando o documento está livre/inexistente (travar uma NPC nova) OU
    // quando o próprio jogador já é o dono atual do lock (reatar, dar um
    // tempo, terminar/liberar) — nunca permite "roubar" o lock de outro uid.
    // ══════════════════════════════════════════════════════
    match /npcs_locks/{npcId} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.resource.data.jogador_uid == request.auth.uid;

      allow update: if isAuth()
        && (
          // Lock estava livre — qualquer jogador autenticado pode travar
          resource.data.status == 'disponivel'
          // OU o jogador já é o dono atual (reatar, dar um tempo, liberar)
          || resource.data.jogador_uid == request.auth.uid
        )
        // O novo dono do lock, após a escrita, só pode ser o próprio
        // jogador que está fazendo a requisição (ou null, ao liberar)
        && (request.resource.data.jogador_uid == request.auth.uid
            || request.resource.data.jogador_uid == null);

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // PROCESSOS
    // Dois tipos de documento: INDIVIDUAL (advogado_uid setado, dono
    // exclusivo) e POOL DO ESCRITÓRIO (advogado_uid null por design,
    // pool_escritorio_id setado — qualquer dono/sócio/funcionário do
    // escritório pode ler e interagir). A regra original só reconhecia
    // 'escritorio_id' (usado nos processos individuais) e nunca
    // 'pool_escritorio_id' (usado nos processos de pool) — por isso
    // processos de pool sempre caíam em "Missing or insufficient
    // permissions" para qualquer um que não fosse o próprio advogado_uid
    // (que para eles é sempre null, então NINGUÉM passava).
    // ══════════════════════════════════════════════════════
    function vinculadoAoEscritorioDoProcesso(procData) {
      let escId = procData.escritorio_id != null ? procData.escritorio_id : procData.pool_escritorio_id;
      return escId != null
        && exists(/databases/$(database)/documents/escritorios/$(escId))
        && (
          isDono(get(/databases/$(database)/documents/escritorios/$(escId)).data)
          || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escId)).data.socios_uids
          || exists(/databases/$(database)/documents/escritorios/$(escId)/funcionarios/$(request.auth.uid))
        );
    }

    match /processos/{processoId} {
      // Leitura simplificada: qualquer autenticado pode ler processos.
      // Justificativa: a regra anterior usava get() para checar vínculo
      // com o escritório a cada documento candidato — isso é custoso e,
      // mais grave, quebra QUERIES DE LISTAGEM (where(...)) como a usada
      // em novoProcessoPool() para contar casos abertos do pool: o
      // Firestore não consegue garantir de forma eficiente que regras
      // dependentes de outro documento valham para toda a lista de
      // resultados, e a query inteira falha com "Missing or insufficient
      // permissions" mesmo que o usuário tivesse acesso a cada documento
      // individualmente. Dados de processo não são sensíveis como senha
      // — o controle de "o que aparece pra quem" já é feito pelas
      // próprias queries no código (where('advogado_uid','==',uid),
      // where('pool_escritorio_id','==',escId) etc.), então liberar a
      // leitura aqui não expõe nada que o código já não filtre.
      allow read: if isAuth();

      // Criação: o próprio advogado (caso individual) OU qualquer
      // dono/sócio/funcionário do escritório (caso de pool, onde
      // advogado_uid é null por design).
      allow create: if isAuth()
        && request.resource.data.status == 'andamento'
        && request.resource.data.progresso == 0
        && (
          request.resource.data.advogado_uid == request.auth.uid
          || vinculadoAoEscritorioDoProcesso(request.resource.data)
        );

      // Update: o próprio advogado (caso individual) OU qualquer
      // dono/sócio/funcionário do escritório (caso de pool) pode jogar
      // a audiência/recurso. Em ambos os casos, advogado_uid e valor da
      // causa não podem ser alterados, e instância não pode retroagir.
      // (Update é sempre em documento único via doc(...).update(), nunca
      // em query de listagem — então get() aqui é seguro e não trava.)
      allow update: if isAuth()
        && (
          resource.data.advogado_uid == request.auth.uid
          || vinculadoAoEscritorioDoProcesso(resource.data)
        )
        && notChanging('advogado_uid')
        && notChanging('valor')
        && request.resource.data.instancia >= resource.data.instancia;

      // Deleção não permitida
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // ESCRITÓRIOS
    // ══════════════════════════════════════════════════════
    match /escritorios/{escritorioId} {
      // Leitura pública (para rankings e busca)
      allow read: if isAuth();

      // Criação: advogado autenticado pode criar seu próprio escritório
      allow create: if isAuth()
        && isDono(request.resource.data);

      // Update: dono, sócio, OU o próprio jogador removendo a si mesmo
      // de funcionarios_uids ao sair do escritório (ver
      // vagas.js::sairEscritorio, que faz arrayRemove(uid) nesse campo
      // sem ser dono nem sócio — é só um empregado saindo).
      allow update: if isAuth()
        && (isDono(resource.data)
            || request.auth.uid in resource.data.socios_uids
            || (
              // Empregado saindo: só pode alterar funcionarios_uids e
              // campos de contagem de vagas (vagas_ocupadas.*), nunca
              // caixa, sócios, ou dados de outros funcionários.
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['funcionarios_uids', 'vagas_ocupadas'])
            ));

      // Subcoleção: funcionários — dono pode tudo; o próprio funcionário
      // (jogador real, identificado pelo campo jogador_uid no documento)
      // pode se autodesativar ao sair (ver vagas.js::sairEscritorio,
      // que marca ativo:false e saiu_em no próprio registro).
      match /funcionarios/{funcId} {
        allow read:   if isAuth();
        allow create: if isAuth()
          && isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data);
        allow update: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || resource.data.jogador_uid == request.auth.uid);
        allow delete: if isAuth()
          && isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data);
      }

      // Subcoleção: oportunidades de serviço — apenas dono/sócios do
      // escritório podem ver e gerenciar (aceitar, delegar, recusar).
      // Sem essa regra, a tela "Clientes" falha com "Missing or
      // insufficient permissions" ao tentar listar oportunidades.
      match /oportunidades/{opId} {
        allow read: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
        allow create: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
        allow update: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
        allow delete: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
      }

      // Subcoleção: carteira de clientes — mesmo padrão de acesso das
      // oportunidades (apenas dono/sócios).
      match /clientes/{clienteId} {
        allow read: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
        allow create: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
        allow update: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
        allow delete: if isAuth()
          && (isDono(get(/databases/$(database)/documents/escritorios/$(escritorioId)).data)
              || request.auth.uid in get(/databases/$(database)/documents/escritorios/$(escritorioId)).data.socios_uids);
      }

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // RANKINGS (somente leitura para jogadores)
    // ══════════════════════════════════════════════════════
    match /rankings/{tipo} {
      allow read: if isAuth();
      allow write: if false; // apenas Cloud Functions
    }

    // ══════════════════════════════════════════════════════
    // EVENTOS GLOBAIS (somente leitura)
    // ══════════════════════════════════════════════════════
    match /eventos/{eventoId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════
    // CONVITES DE ESCRITÓRIO
    // ══════════════════════════════════════════════════════
    match /convites/{conviteId} {
      // Destinatário e remetente podem ler
      allow read: if isAuth() && (
        resource.data.para_uid == request.auth.uid ||
        resource.data.de_uid == request.auth.uid
      );
      // Sócio do escritório pode criar convite
      allow create: if isAuth()
        && request.resource.data.de_uid == request.auth.uid
        && request.resource.data.status == 'pendente';
      // Destinatário aceita ou recusa
      allow update: if isAuth()
        && resource.data.para_uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['status', 'respondido_em'])
        && request.resource.data.status in ['aceito', 'recusado'];
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // SESSÕES DE QUIZ/PROVA (temporárias)
    // ══════════════════════════════════════════════════════
    match /sessoes_prova/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ══════════════════════════════════════════════════════
    // BLOQUEAR TUDO QUE NÃO FOI EXPLICITAMENTE PERMITIDO
    // ══════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
